package root:component;

world root {
  import starstream:std/builtin;

  export my-utxo: interface {
    resource my-utxo;

    hello-utxo: func(x: s32);

    foo: func();
  }
}
package starstream:std {
  interface builtin {
    implements-method: func(hash: tuple<u64, u64, u64, u64>);
  }
}
