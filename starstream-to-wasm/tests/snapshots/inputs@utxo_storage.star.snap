==== WIT ====
package root:component;

world root {
  export my-utxo: interface {
    resource utxo {
      increment: static func() -> utxo;
      increment-mult: static func() -> utxo;
    }

    record storage {
      counter: s64,
      multiplier: s64,
    }

    get-storage: func(self: borrow<utxo>) -> storage;

    set-storage: func(storage: storage) -> utxo;
  }
}
