---
abi MyAbi {
    fn transfer(amount: i64) -> bool;
}

fn test(x: Utxo) {
    if x is MyAbi {
        x.transfer(100);
    } else if x is MyAbi {
        x.transfer(200);
    } else {
        0;
    }
}
