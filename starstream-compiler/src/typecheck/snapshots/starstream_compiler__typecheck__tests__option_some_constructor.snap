T-Fn: test => ()
  T-Let: {test: fn() -> () [test]} ⊢ let x = Option::Some(42); ⇒ Option
    T-Call: {test: fn() -> () [test]} ⊢ Option::Some(42) ⇒ Option
      T-Var: {test: fn() -> () [test]} ⊢ Option::Some ⇒ fn(t3) -> Option [1]
      T-Int: {test: fn() -> () [test]} ⊢ 42 ⇒ i64
      Unify-Var: i64 ~ t3 => {i64/t4}
