T-Fn: main => ()
  T-Let: {main: fn() -> ()} ⊢ let x = 1; ⇒ i64
    T-Int: {main: fn() -> ()} ⊢ 1 ⇒ i64
  T-Let: {main: fn() -> (), x: i64} ⊢ let _y = disclose(x); ⇒ i64
    T-Disclose: {main: fn() -> (), x: i64} ⊢ disclose(x) ⇒ i64
      T-Var: {main: fn() -> (), x: i64} ⊢ x ⇒ i64
