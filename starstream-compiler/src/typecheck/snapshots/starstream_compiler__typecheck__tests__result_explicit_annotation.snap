T-Fn: test => ()
  T-Let: {test: fn() -> () [test]} ⊢ let x: Result<i64, bool> = Result::Ok(42); ⇒ Result<i64, bool>
    T-Call: {test: fn() -> () [test]} ⊢ Result::Ok(42) ⇒ Result
      T-Var: {test: fn() -> () [test]} ⊢ Result::Ok ⇒ fn(t3) -> Result [0]
      T-Int: {test: fn() -> () [test]} ⊢ 42 ⇒ i64
      Unify-Var: i64 ~ t3 => {i64/t5}
    Unify-Enum: Result<i64, bool> ~ Result => {bool/t4, i64/t3}
      Unify-Var: i64 ~ i64 => {i64/t3}
      Unify-Var: bool ~ t4 => {bool/t4}
