---
source: starstream-compiler/src/typecheck/tests.rs
description: "Source:\n\nabi AbiA {\n    fn foo() -> i64;\n}\n\nabi AbiB {\n    fn bar() -> bool;\n}\n\nfn test(x: Utxo) {\n    if x is AbiA {\n        x.foo();\n    } else if x is AbiB {\n        x.bar();\n    }\n}\n"
---
T-Fn: test => ()
  T-ReturnTail: if x is AbiA {
    x.foo();
} else if x is AbiB {
    x.bar();
} => ()
    T-If: {x: Utxo} ⊢ if x is AbiA {
    x.foo();
} else if x is AbiB {
    x.bar();
} ⇒ ()
      T-Expr: {x: AbiA} ⊢ x.foo(); ⇒ ()
        T-Call: {x: AbiA} ⊢ x.foo() ⇒ i64
          T-FieldAccess: {x: AbiA} ⊢ x.foo ⇒ fn() -> i64
            T-Var: {x: AbiA} ⊢ x ⇒ AbiA
      T-Expr: {x: AbiB} ⊢ x.bar(); ⇒ ()
        T-Call: {x: AbiB} ⊢ x.bar() ⇒ bool
          T-FieldAccess: {x: AbiB} ⊢ x.bar ⇒ fn() -> bool
            T-Var: {x: AbiB} ⊢ x ⇒ AbiB
      Unify-Const: () ~ () => {}
      Unify-Const: () ~ () => {}
    Unify-Const: () ~ () => {}
