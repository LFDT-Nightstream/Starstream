---
source: starstream-compiler/src/typecheck/tests.rs
description: "Source:\n\nabi TokenAbi {\n    fn transfer(amount: i64) -> bool;\n}\n\nfn test(x: Utxo) {\n    if x is TokenAbi {\n        x.transfer(100);\n    }\n}\n"
---
T-Fn: test => ()
  T-ReturnTail: if x is TokenAbi {
    x.transfer(100);
} => ()
    T-If: {x: Utxo} ⊢ if x is TokenAbi {
    x.transfer(100);
} ⇒ ()
      T-Expr: {x: TokenAbi} ⊢ x.transfer(100); ⇒ ()
        T-Call: {x: TokenAbi} ⊢ x.transfer(100) ⇒ bool
          T-FieldAccess: {x: TokenAbi} ⊢ x.transfer ⇒ fn(i64) -> bool
            T-Var: {x: TokenAbi} ⊢ x ⇒ TokenAbi
          T-Int: {x: TokenAbi} ⊢ 100 ⇒ i64
          Unify-Var: i64 ~ i64 => {i64/t3}
      Unify-Const: () ~ () => {}
    Unify-Const: () ~ () => {}
